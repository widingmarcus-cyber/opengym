{
  "database_version": "v3.2.0",
  "schema": {
    "users": {
      "columns": [
        "id",
        "name",
        "email"
      ]
    },
    "orders": {
      "columns": [
        "id",
        "user_id",
        "total"
      ]
    }
  },
  "feature_flags": {
    "new_ui": false,
    "beta_api": false,
    "dark_mode": true
  },
  "config": {
    "max_connections": 100,
    "timeout": 30,
    "cache_ttl": 300
  },
  "services": {
    "api": "running",
    "worker": "running",
    "scheduler": "running"
  }
}