{
  "description": "Schema versions returned by tools/api.py based on cumulative call count",
  "schemas": {
    "v1": {
      "calls": "1-3",
      "format": {
        "name": "string",
        "value": "float",
        "in_stock": "boolean"
      },
      "example": {"name": "laptop", "value": 999.99, "in_stock": true}
    },
    "v2": {
      "calls": "4-6",
      "format": {
        "item_name": "string",
        "item_value": "float",
        "available": "boolean",
        "unit": "string"
      },
      "example": {"item_name": "monitor", "item_value": 399.99, "available": true, "unit": "USD"},
      "stderr_hint": "SCHEMA_VERSION: v2"
    },
    "v3": {
      "calls": "7-8",
      "format": {
        "n": "string",
        "v": "float",
        "s": "boolean",
        "u": "string",
        "deprecated": "boolean (always true)"
      },
      "example": {"n": "microphone", "v": 129.99, "s": false, "u": "USD", "deprecated": true},
      "stderr_hint": "SCHEMA_VERSION: v3"
    }
  },
  "unified_output_format": {
    "name": "string",
    "value": "float",
    "in_stock": "boolean"
  }
}
